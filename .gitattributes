* text=auto

# Source and config files stay LF across platforms.
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sql text eol=lf
*.env text eol=lf
*.example text eol=lf
*.properties text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.md text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Native Windows scripts use CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
