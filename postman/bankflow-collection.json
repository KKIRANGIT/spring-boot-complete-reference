{
  "info": {
    "_postman_id": "2ebad7b8-6357-4e4e-99e0-0c69e3af01c1",
    "name": "BankFlow",
    "description": "Local BankFlow collection routed through the API Gateway.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const publicPaths = [",
          "  '/api/v1/auth/register',",
          "  '/api/v1/auth/login',",
          "  '/api/v1/auth/refresh-token',",
          "  '/actuator/',",
          "  '/fallback/'",
          "];",
          "const url = pm.request.url.toString();",
          "const isPublic = publicPaths.some(path => url.includes(path));",
          "if (!isPublic) {",
          "  const token = pm.environment.get('accessToken');",
          "  if (token) {",
          "    pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + token });",
          "  }",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"demo_user\",\n  \"email\": \"demo_user@bankflow.local\",\n  \"password\": \"Password1!\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const resp = pm.response.json();",
                  "pm.environment.set('accessToken', resp.data.accessToken);",
                  "pm.environment.set('refreshToken', resp.data.refreshToken);",
                  "pm.environment.set('userId', resp.data.userId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usernameOrEmail\": \"demo_user\",\n  \"password\": \"Password1!\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/auth/me"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/refresh-token"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Account",
      "item": [
        {
          "name": "Create Account",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const resp = pm.response.json();",
                  "pm.test('status 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "if (!pm.environment.get('accountId')) {",
                  "  pm.environment.set('accountId', resp.data.id);",
                  "} else {",
                  "  pm.environment.set('secondAccountId', resp.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountType\": \"SAVINGS\",\n  \"initialDeposit\": 1000.00,\n  \"currency\": \"INR\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/accounts"
          }
        },
        {
          "name": "Get Account by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/accounts/{{accountId}}"
          }
        },
        {
          "name": "Get My Accounts",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/accounts/my"
          }
        },
        {
          "name": "Get Balance",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/accounts/{{accountId}}/balance"
          }
        },
        {
          "name": "Get Statement",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/accounts/{{accountId}}/statement?page=0&size=20"
          }
        }
      ]
    },
    {
      "name": "Payment",
      "item": [
        {
          "name": "Transfer Payment",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const resp = pm.response.json();",
                  "pm.test('status 202', function () {",
                  "  pm.response.to.have.status(202);",
                  "});",
                  "pm.environment.set('transactionId', resp.data.transactionId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{$guid}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fromAccountId\": \"{{accountId}}\",\n  \"toAccountId\": \"{{secondAccountId}}\",\n  \"amount\": 100.00,\n  \"currency\": \"INR\",\n  \"description\": \"Local transfer test\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/payments/transfers"
          }
        },
        {
          "name": "Get Transaction by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/payments/{{transactionId}}"
          }
        }
      ]
    }
  ]
}
